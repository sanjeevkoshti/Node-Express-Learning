<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(post of posts) { %>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <p class="content"><%= post.content %></p>
            <a href="http://localhost:3000/posts/<%= post.id %>">See in Detail</a>&nbsp;&nbsp;&nbsp;
            <a href="http://localhost:3000/posts/<%= post.id %>/edit">Edit Post</a>&nbsp;&nbsp;&nbsp;
            <form action="/posts/<%= post.id %>?_method=DELETE" method="POST">
                <button style="color: red; cursor: pointer; margin-top: 1rem;">Delete</button>
            </form>
        </div>
    <% } %>

    <br><br>
    <a href="http://localhost:3000/posts/new">Create New Post</a>
</body>
</html>